# Copy this file to .env and fill in real values.
# .env is gitignored — it will never be committed.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Must be identical across auth-service and wallet-service —
# wallet-service validates tokens that auth-service issues using this same secret.
JWT_SECRET=replace-with-a-long-random-string

# Gmail App Password (Google Account -> Security -> App Passwords)
# Never your real Gmail login password.
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
